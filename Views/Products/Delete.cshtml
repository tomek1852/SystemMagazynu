@model SystemMagazynu.Models.Product

@{
    ViewData["Title"] = "Usuń produkt";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Usuń produkt</h2>
    <a asp-action="Index" class="btn btn-secondary">← Powrót</a>
</div>

<div class="alert alert-danger">
    Czy na pewno chcesz usunąć produkt <strong>@Model.Name</strong>?
    Tej operacji nie można cofnąć.
</div>

<dl class="row col-md-6">
    <dt class="col-sm-4">Nazwa</dt>
    <dd class="col-sm-8">@Model.Name</dd>

    <dt class="col-sm-4">Kod katalogowy</dt>
    <dd class="col-sm-8">@Model.CatalogNumber</dd>

    <dt class="col-sm-4">Kategoria</dt>
    <dd class="col-sm-8">@Model.Category?.Name</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Tak, usuń</button>
    <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
</form>