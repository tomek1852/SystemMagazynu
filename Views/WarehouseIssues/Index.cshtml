@model IEnumerable<SystemMagazynu.Models.WarehouseMovement>

@{
    ViewData["Title"] = "Wydania towarów";
    bool canIssue = User.IsInRole("Administrator") || User.IsInRole("Magazynier") || User.IsInRole("KierownikMagazynu");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Wydania towarów</h2>
    @if (canIssue)
    {
        <a asp-action="Create" class="btn btn-primary">+ Nowe wydanie</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <select name="warehouseId" class="form-select" asp-items="ViewBag.Warehouses">
            <option value="">-- Wszystkie magazyny --</option>
        </select>
    </div>
    <div class="col-md-4">
        <select name="productId" class="form-select" asp-items="ViewBag.Products">
            <option value="">-- Wszystkie produkty --</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Filtruj</button>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Data</th>
            <th>Produkt</th>
            <th>Magazyn</th>
            <th>Ilość</th>
            <th>Dokument</th>
            <th>Uwagi</th>
            <th>Użytkownik</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var movement in Model)
        {
            <tr>
                <td>@movement.MovementDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@movement.Product?.Name</td>
                <td>@movement.Warehouse?.Name</td>
                <td>@movement.Quantity</td>
                <td>@movement.SourceDocument</td>
                <td>@movement.Notes</td>
                <td>@movement.User?.FullName</td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="text-center text-muted mt-4">
        <p>Brak zarejestrowanych wydań spełniających kryteria.</p>
    </div>
}
