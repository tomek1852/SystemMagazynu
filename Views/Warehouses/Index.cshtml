@model IEnumerable<SystemMagazynu.Models.Warehouse>

@{
    ViewData["Title"] = "Magazyny";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Magazyny</h2>
    @if (User.IsInRole("Administrator") || User.IsInRole("KierownikMagazynu"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Dodaj magazyn</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="searchName" value="@ViewBag.SearchName"
               class="form-control" placeholder="Szukaj po nazwie..." />
    </div>
    <div class="col-md-4">
        <input type="text" name="searchCity" value="@ViewBag.SearchCity"
               class="form-control" placeholder="Miasto..." />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Szukaj</button>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nazwa</th>
            <th>Adres</th>
            <th>Miasto</th>
            <th>Status</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var warehouse in Model)
        {
            <tr>
                <td>@warehouse.Name</td>
                <td>@warehouse.Street @warehouse.BuildingNumber</td>
                <td>@warehouse.PostalCode @warehouse.City</td>
                <td>
                    @if (warehouse.IsActive)
                    {
                        <span class="badge bg-success">Aktywny</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Nieaktywny</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@warehouse.Id"
                       class="btn btn-sm btn-info">Szczegóły</a>

                    @if (User.IsInRole("Administrator") || User.IsInRole("KierownikMagazynu"))
                    {
                        <a asp-action="Edit" asp-route-id="@warehouse.Id"
                           class="btn btn-sm btn-warning">Edytuj</a>
                        <a asp-action="Delete" asp-route-id="@warehouse.Id"
                           class="btn btn-sm btn-danger">Usuń</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="text-center text-muted mt-4">
        <p>Brak magazynów spełniających kryteria wyszukiwania.</p>
    </div>
}
