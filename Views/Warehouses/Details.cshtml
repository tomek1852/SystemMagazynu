@model SystemMagazynu.Models.Warehouse

@{
    ViewData["Title"] = "Szczegóły magazynu";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Szczegóły magazynu</h2>
    <a asp-action="Index" class="btn btn-secondary">← Powrót</a>
</div>

<dl class="row">
    <dt class="col-sm-3">Nazwa</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Adres</dt>
    <dd class="col-sm-9">@Model.Street @Model.BuildingNumber, @Model.PostalCode @Model.City, @Model.Country</dd>

    <dt class="col-sm-3">Opis</dt>
    <dd class="col-sm-9">@Model.Description</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @if (Model.IsActive)
        {
            <span class="badge bg-success">Aktywny</span>
        }
        else
        {
            <span class="badge bg-secondary">Nieaktywny</span>
        }
    </dd>
</dl>

<h4 class="mt-4">Stany magazynowe</h4>

@if (Model.WarehouseStocks.Any())
{
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Produkt</th>
                <th>Kod katalogowy</th>
                <th>Ilość</th>
                <th>Min. stan</th>
                <th>Ostatnia aktualizacja</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var stock in Model.WarehouseStocks.OrderBy(s => s.Product!.Name))
            {
                var belowMin = stock.Product != null && stock.Quantity <= stock.Product.MinimumStock;
                <tr class="@(belowMin ? "table-danger" : "")">
                    <td>@stock.Product?.Name</td>
                    <td><code>@stock.Product?.CatalogNumber</code></td>
                    <td>@stock.Quantity</td>
                    <td>@stock.Product?.MinimumStock</td>
                    <td>@stock.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Brak stanów magazynowych dla tego magazynu.</p>
}

<div class="mt-3">
    @if (User.IsInRole("Administrator") || User.IsInRole("KierownikMagazynu"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edytuj</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Usuń</a>
    }
</div>
