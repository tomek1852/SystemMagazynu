@model SystemMagazynu.Models.Warehouse

@{
    ViewData["Title"] = "Usuń magazyn";
    var hasStocks = Model.WarehouseStocks.Any();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Usuń magazyn</h2>
    <a asp-action="Index" class="btn btn-secondary">← Powrót</a>
</div>

<div class="alert alert-warning">
    Czy na pewno chcesz usunąć poniższy magazyn?
</div>

<dl class="row">
    <dt class="col-sm-3">Nazwa</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Adres</dt>
    <dd class="col-sm-9">@Model.Street @Model.BuildingNumber, @Model.PostalCode @Model.City, @Model.Country</dd>
</dl>

@if (hasStocks)
{
    <div class="alert alert-danger">
        Ten magazyn ma powiązane stany magazynowe. Usunięcie nie będzie możliwe.
        Zamiast tego oznacz go jako nieaktywny w edycji.
    </div>
}

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />

    <button type="submit" class="btn btn-danger" disabled="@hasStocks">Usuń</button>
    <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
</form>
