@model SystemMagazynu.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Pulpit";
}

<h2 class="mb-4">Pulpit</h2>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-bg-primary h-100">
            <div class="card-body">
                <h6 class="card-title">Produkty</h6>
                <p class="display-6 mb-0">@Model.ProductsCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-secondary h-100">
            <div class="card-body">
                <h6 class="card-title">Magazyny</h6>
                <p class="display-6 mb-0">@Model.WarehousesCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-secondary h-100">
            <div class="card-body">
                <h6 class="card-title">Dostawcy</h6>
                <p class="display-6 mb-0">@Model.SuppliersCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card @(Model.ActiveAlertsCount > 0 ? "text-bg-danger" : "text-bg-success") h-100">
            <div class="card-body">
                <h6 class="card-title">Aktywne alerty</h6>
                <p class="display-6 mb-0">@Model.ActiveAlertsCount</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-title text-muted">Pozycje poniżej minimum</h6>
                <p class="h3 mb-0">@Model.LowStockPositions</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-title text-muted">Dostawy w tym miesiącu</h6>
                <p class="h3 mb-0">@Model.DeliveriesThisMonth</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-title text-muted">Wydania w tym miesiącu</h6>
                <p class="h3 mb-0">@Model.IssuesThisMonth</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Ostatnie dostawy</span>
                <a asp-controller="Deliveries" asp-action="Index" class="btn btn-sm btn-outline-secondary">Wszystkie</a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentDeliveries.Any())
                {
                    <table class="table table-sm mb-0">
                        <tbody>
                            @foreach (var d in Model.RecentDeliveries)
                            {
                                <tr>
                                    <td>@d.DeliveryNumber</td>
                                    <td>@d.Supplier?.Name</td>
                                    <td>@d.DeliveryDate.ToString("yyyy-MM-dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">Brak dostaw.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Aktywne alerty</span>
                <a asp-controller="StockAlerts" asp-action="Index" class="btn btn-sm btn-outline-secondary">Wszystkie</a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentAlerts.Any())
                {
                    <table class="table table-sm mb-0">
                        <tbody>
                            @foreach (var a in Model.RecentAlerts)
                            {
                                <tr>
                                    <td>@a.Product?.Name</td>
                                    <td>@a.Warehouse?.Name</td>
                                    <td>
                                        @if (a.CurrentQuantity == 0)
                                        {
                                            <span class="badge bg-danger">Brak</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">@a.CurrentQuantity szt.</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">Brak aktywnych alertów.</p>
                }
            </div>
        </div>
    </div>
</div>
