@model IEnumerable<SystemMagazynu.Models.WarehouseMovement>

@{
    ViewData["Title"] = "Raport: ruchy magazynowe";

    Func<SystemMagazynu.Models.MovementType, string> typeLabel = t => t switch
    {
        SystemMagazynu.Models.MovementType.Receipt => "Przyjęcie",
        SystemMagazynu.Models.MovementType.Issue => "Wydanie",
        SystemMagazynu.Models.MovementType.Correction => "Korekta",
        _ => t.ToString()
    };

    string? selectedType = ViewBag.Type?.ToString();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Raport: ruchy magazynowe</h2>
    <a asp-action="Index" class="btn btn-secondary">← Raporty</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-2">
        <input type="date" name="from" value="@ViewBag.From" class="form-control" />
    </div>
    <div class="col-md-2">
        <input type="date" name="to" value="@ViewBag.To" class="form-control" />
    </div>
    <div class="col-md-2">
        <select name="type" class="form-select">
            <option value="">-- Typ --</option>
            <option value="Receipt" selected="@(selectedType == "Receipt")">Przyjęcie</option>
            <option value="Issue" selected="@(selectedType == "Issue")">Wydanie</option>
            <option value="Correction" selected="@(selectedType == "Correction")">Korekta</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="warehouseId" class="form-select" asp-items="ViewBag.Warehouses">
            <option value="">-- Magazyn --</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="productId" class="form-select" asp-items="ViewBag.Products">
            <option value="">-- Produkt --</option>
        </select>
    </div>
    <div class="col-md-1">
        <button type="submit" class="btn btn-secondary w-100">Generuj</button>
    </div>
    <div class="col-md-1">
        <a class="btn btn-success w-100"
           asp-action="MovementsCsv"
           asp-route-from="@ViewBag.From"
           asp-route-to="@ViewBag.To"
           asp-route-type="@selectedType"
           asp-route-warehouseId="@ViewBag.WarehouseId"
           asp-route-productId="@ViewBag.ProductId">CSV</a>
    </div>
</form>

<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>Data</th>
            <th>Typ</th>
            <th>Produkt</th>
            <th>Magazyn</th>
            <th>Ilość</th>
            <th>Dokument</th>
            <th>Użytkownik</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.MovementDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@typeLabel(m.MovementType)</td>
                <td>@m.Product?.Name</td>
                <td>@m.Warehouse?.Name</td>
                <td>@m.Quantity</td>
                <td>@m.SourceDocument</td>
                <td>@m.User?.FullName</td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted text-center mt-4">Brak ruchów w wybranym okresie.</p>
}
