@model IEnumerable<SystemMagazynu.Models.Delivery>

@{
    ViewData["Title"] = "Raport: dostawy";
    decimal grandTotal = Model.Sum(d => d.DeliveryItems.Sum(i => i.Quantity * i.UnitPrice));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Raport: dostawy</h2>
    <a asp-action="Index" class="btn btn-secondary">← Raporty</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-2">
        <input type="date" name="from" value="@ViewBag.From" class="form-control" />
    </div>
    <div class="col-md-2">
        <input type="date" name="to" value="@ViewBag.To" class="form-control" />
    </div>
    <div class="col-md-3">
        <select name="supplierId" class="form-select" asp-items="ViewBag.Suppliers">
            <option value="">-- Dostawca --</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="warehouseId" class="form-select" asp-items="ViewBag.Warehouses">
            <option value="">-- Magazyn --</option>
        </select>
    </div>
    <div class="col-md-1">
        <button type="submit" class="btn btn-secondary w-100">Generuj</button>
    </div>
    <div class="col-md-2">
        <a class="btn btn-success w-100"
           asp-action="DeliveriesCsv"
           asp-route-from="@ViewBag.From"
           asp-route-to="@ViewBag.To"
           asp-route-supplierId="@ViewBag.SupplierId"
           asp-route-warehouseId="@ViewBag.WarehouseId">Eksportuj CSV</a>
    </div>
</form>

<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>Numer dostawy</th>
            <th>Data</th>
            <th>Dostawca</th>
            <th>Magazyn</th>
            <th>Liczba pozycji</th>
            <th>Wartość</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.DeliveryNumber</td>
                <td>@d.DeliveryDate.ToString("yyyy-MM-dd")</td>
                <td>@d.Supplier?.Name</td>
                <td>@d.Warehouse?.Name</td>
                <td>@d.DeliveryItems.Count</td>
                <td>@(d.DeliveryItems.Sum(i => i.Quantity * i.UnitPrice).ToString("0.00"))</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="5" class="text-end">Suma wartości:</th>
            <th>@grandTotal.ToString("0.00")</th>
        </tr>
    </tfoot>
</table>

@if (!Model.Any())
{
    <p class="text-muted text-center mt-4">Brak dostaw w wybranym okresie.</p>
}
