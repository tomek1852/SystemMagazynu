@model SystemMagazynu.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Logowanie";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logowanie – System Magazynu</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            body {
                background-color: #f0f2f5;
            }
            .login-card {
                max-width: 420px;
                margin: 100px auto;
                border-radius: 12px;
                box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            }
            .login-header {
                background-color: #0d6efd;
                color: white;
                border-radius: 12px 12px 0 0;
                padding: 24px;
                text-align: center;
            }
            .login-header h4 {
                margin: 0;
                font-weight: 600;
            }
    </style>
</head>
<body>
    <div class="login-card card">
        <div class="login-header">
            <h4>System Magazynu</h4>
            <small>Zaloguj się do systemu</small>
        </div>
        <div class="card-body p-4">

            <div asp-validation-summary="All" class="alert alert-danger text-danger"></div>

             <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="adres@email.pl" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">Zaloguj się</button>
                </div>
            </form>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>