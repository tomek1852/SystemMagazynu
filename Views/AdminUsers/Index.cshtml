@model IEnumerable<SystemMagazynu.ViewModels.AdminUserListItem>

@{
    ViewData["Title"] = "Użytkownicy";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Panel administratora — użytkownicy</h2>
    <a asp-action="Create" class="btn btn-primary">+ Dodaj użytkownika</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Email</th>
            <th>Imię i nazwisko</th>
            <th>Rola</th>
            <th>Status</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.FullName</td>
                <td>@user.Role</td>
                <td>
                    @if (user.IsActive)
                    {
                        <span class="badge bg-success">Aktywny</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Nieaktywny</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Edytuj</a>
                    <a asp-action="ResetPassword" asp-route-id="@user.Id" class="btn btn-sm btn-info">Reset hasła</a>
                    <form asp-action="ToggleActive" asp-route-id="@user.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        @if (user.IsActive)
                        {
                            <button type="submit" class="btn btn-sm btn-outline-danger">Dezaktywuj</button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-sm btn-outline-success">Aktywuj</button>
                        }
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
