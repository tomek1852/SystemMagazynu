@model SystemMagazynu.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset hasła";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Reset hasła użytkownika</h2>
    <a asp-action="Index" class="btn btn-secondary">← Powrót</a>
</div>

<div class="row">
    <div class="col-md-6">
        <p class="text-muted">Ustawiasz nowe hasło dla: <strong>@Model.Email</strong></p>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Email" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" class="form-control" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                <div class="form-text">Min. 8 znaków, w tym cyfra, mała i wielka litera.</div>
            </div>

            <button type="submit" class="btn btn-primary">Zresetuj hasło</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
