@model SystemMagazynu.Models.Supplier

@{
    ViewData["Title"] = "Szczegóły dostawcy";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Szczegóły dostawcy</h2>
    <a asp-action="Index" class="btn btn-secondary">← Powrót</a>
</div>

<dl class="row">
    <dt class="col-sm-3">Nazwa</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">NIP</dt>
    <dd class="col-sm-9">@Model.NIP</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Telefon</dt>
    <dd class="col-sm-9">@Model.Phone</dd>

    <dt class="col-sm-3">Adres</dt>
    <dd class="col-sm-9">@Model.Street @Model.BuildingNumber, @Model.PostalCode @Model.City, @Model.Country</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @if (Model.IsActive)
        {
            <span class="badge bg-success">Aktywny</span>
        }
        else
        {
            <span class="badge bg-secondary">Nieaktywny</span>
        }
    </dd>
</dl>

<h4 class="mt-4">Historia współpracy (dostawy)</h4>

@if (Model.Deliveries.Any())
{
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Numer dostawy</th>
                <th>Data</th>
                <th>Magazyn</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var delivery in Model.Deliveries.OrderByDescending(d => d.DeliveryDate))
            {
                <tr>
                    <td>@delivery.DeliveryNumber</td>
                    <td>@delivery.DeliveryDate.ToString("yyyy-MM-dd")</td>
                    <td>@delivery.Warehouse?.Name</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Brak zarejestrowanych dostaw od tego dostawcy.</p>
}

<div class="mt-3">
    @if (User.IsInRole("Administrator") || User.IsInRole("PracownikZakupow"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edytuj</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Usuń</a>
    }
</div>
