@model IEnumerable<SystemMagazynu.Models.Supplier>

@{
    ViewData["Title"] = "Dostawcy";
    bool canManage = User.IsInRole("Administrator") || User.IsInRole("PracownikZakupow");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Dostawcy</h2>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-primary">+ Dodaj dostawcę</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <input type="text" name="searchName" value="@ViewBag.SearchName"
               class="form-control" placeholder="Szukaj po nazwie..." />
    </div>
    <div class="col-md-3 d-flex align-items-center">
        <div class="form-check">
            <input type="checkbox" name="onlyActive" value="true" class="form-check-input"
                   id="onlyActive" @(ViewBag.OnlyActive == true ? "checked" : "") />
            <label class="form-check-label" for="onlyActive">Tylko aktywni</label>
        </div>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Szukaj</button>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nazwa</th>
            <th>NIP</th>
            <th>Email</th>
            <th>Telefon</th>
            <th>Status</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var supplier in Model)
        {
            <tr>
                <td>@supplier.Name</td>
                <td>@supplier.NIP</td>
                <td>@supplier.Email</td>
                <td>@supplier.Phone</td>
                <td>
                    @if (supplier.IsActive)
                    {
                        <span class="badge bg-success">Aktywny</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Nieaktywny</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@supplier.Id"
                       class="btn btn-sm btn-info">Szczegóły</a>

                    @if (canManage)
                    {
                        <a asp-action="Edit" asp-route-id="@supplier.Id"
                           class="btn btn-sm btn-warning">Edytuj</a>

                        @if (supplier.IsActive)
                        {
                            <form asp-action="Deactivate" asp-route-id="@supplier.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Dezaktywuj</button>
                            </form>
                        }

                        <a asp-action="Delete" asp-route-id="@supplier.Id"
                           class="btn btn-sm btn-danger">Usuń</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="text-center text-muted mt-4">
        <p>Brak dostawców spełniających kryteria wyszukiwania.</p>
    </div>
}
