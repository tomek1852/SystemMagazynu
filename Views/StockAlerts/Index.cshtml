@model IEnumerable<SystemMagazynu.Models.StockAlert>

@{
    ViewData["Title"] = "Alerty magazynowe";
    bool canManage = User.IsInRole("Administrator") || User.IsInRole("KierownikMagazynu");
    string currentStatus = ViewBag.Status as string ?? "active";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Alerty magazynowe</h2>
    @if (canManage)
    {
        <form asp-action="Rescan" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-primary">Przeskanuj stany</button>
        </form>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card @(((int)ViewBag.ActiveCount) > 0 ? "text-bg-warning" : "text-bg-light")">
            <div class="card-body">
                <h6 class="card-title">Aktywne alerty</h6>
                <p class="display-6 mb-0">@ViewBag.ActiveCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card @(((int)ViewBag.OutOfStockCount) > 0 ? "text-bg-danger" : "text-bg-light")">
            <div class="card-body">
                <h6 class="card-title">Braki (stan = 0)</h6>
                <p class="display-6 mb-0">@ViewBag.OutOfStockCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-bg-light">
            <div class="card-body">
                <h6 class="card-title text-muted">Rozwiązane</h6>
                <p class="display-6 mb-0">@ViewBag.ResolvedCount</p>
            </div>
        </div>
    </div>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <select name="status" class="form-select">
            <option value="active" selected="@(currentStatus == "active")">Aktywne</option>
            <option value="resolved" selected="@(currentStatus == "resolved")">Rozwiązane</option>
            <option value="all" selected="@(currentStatus == "all")">Wszystkie</option>
        </select>
    </div>
    <div class="col-md-3">
        <select name="warehouseId" class="form-select" asp-items="ViewBag.Warehouses">
            <option value="">-- Wszystkie magazyny --</option>
        </select>
    </div>
    <div class="col-md-3">
        <select name="productId" class="form-select" asp-items="ViewBag.Products">
            <option value="">-- Wszystkie produkty --</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Filtruj</button>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Produkt</th>
            <th>Magazyn</th>
            <th>Typ</th>
            <th>Aktualna ilość</th>
            <th>Min. stan</th>
            <th>Utworzono</th>
            <th>Status</th>
            @if (canManage)
            {
                <th>Akcje</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var alert in Model)
        {
            <tr>
                <td>@alert.Product?.Name</td>
                <td>@alert.Warehouse?.Name</td>
                <td>
                    @if (alert.CurrentQuantity == 0)
                    {
                        <span class="badge bg-danger">Brak produktu</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Niski stan</span>
                    }
                </td>
                <td>@alert.CurrentQuantity</td>
                <td>@alert.MinimumStock</td>
                <td>@alert.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    @if (alert.Status == SystemMagazynu.Models.AlertStatus.Active)
                    {
                        <span class="badge bg-secondary">Aktywny</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Rozwiązany</span>
                    }
                </td>
                @if (canManage)
                {
                    <td>
                        @if (alert.Status == SystemMagazynu.Models.AlertStatus.Active)
                        {
                            <form asp-action="Resolve" asp-route-id="@alert.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success">Oznacz jako rozwiązany</button>
                            </form>
                        }
                    </td>
                }
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="text-center text-muted mt-4">
        <p>Brak alertów spełniających kryteria.</p>
    </div>
}
